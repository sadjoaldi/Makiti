# ─────────────────────────────────────────────
# MAKITI — Variables d'environnement PRODUCTION
# Copier vers .env.prod sur le VPS et remplir avec les vraies valeurs
# (récupérables dans Bitwarden → dossier Makiti)
# ─────────────────────────────────────────────

# ─── Base de données PostgreSQL ───
POSTGRES_USER=makiti
POSTGRES_PASSWORD=          
POSTGRES_DB=makiti_prod

# ─── JWT ───
JWT_SECRET=                 #  JWT_SECRET
JWT_EXPIRES_IN=7d

# ─── Cloudinary ───
CLOUDINARY_CLOUD_NAME=      #  CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY=         #  CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=      #  CLOUDINARY_API_SECRET

# ─── Africa's Talking (SMS) ───
AT_API_KEY=                 #  AT_API_KEY
AT_USERNAME=                #  AT_USERNAME

# ─── Sentry ───
SENTRY_DSN=                 #  SENTRY_DSN (backend NestJS)
NEXT_PUBLIC_SENTRY_DSN=     #  SENTRY_DSN (frontend Next.js)

# ─── Compte admin de secours ───
ADMIN_EMAIL=                #  ADMIN_EMAIL
ADMIN_PHONE=                #  ADMIN_PHONE
ADMIN_PASSWORD=             #  ADMIN_PASSWORD

# ─── URLs publiques (à finaliser avec le domaine) ───
# Remplacer makiti.xxx par le vrai domaine au déploiement
FRONTEND_URL=https://makiti.xxx
NEXT_PUBLIC_API_URL=https://makiti.xxx/api/v1
NEXT_PUBLIC_SITE_URL=https://makiti.xxx